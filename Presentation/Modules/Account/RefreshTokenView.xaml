<UserControl x:Class="Aksl.Modules.Account.Views.RefreshTokenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ei="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:behaviors="clr-namespace:Aksl.Xaml.Behaviors;assembly=Aksl.Toolkit"
             xmlns:materialDesign="clr-namespace:Aksl.Toolkit.Controls;assembly=Aksl.Toolkit.Controls"
             xmlns:aksl="clr-namespace:Aksl.Toolkit.UI.Controls;assembly=Aksl.Toolkit"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
    </UserControl.Resources>

    <Grid Margin="2,2,2,2">
        <Border Margin="0"
                Background="WhiteSmoke"
                BorderThickness="1,1,1,1"
                CornerRadius="2">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0"
                                     EndPoint="1,1"
                                     MappingMode="RelativeToBoundingBox"
                                     SpreadMethod="Pad">
                    <LinearGradientBrush.GradientStops>
                        <GradientStop Color="Black"
                                      Offset="0.0" />
                        <GradientStop Color="WhiteSmoke"
                                      Offset="0.5" />
                        <GradientStop Color="Black"
                                      Offset="1.0" />
                    </LinearGradientBrush.GradientStops>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Grid Visibility="{Binding Path=IsLoading,Converter={StaticResource booleanNegationToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="100" />
                    <RowDefinition Height="80" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="30" />
                    <RowDefinition Height="60" />
                    <RowDefinition Height="100" />
                    <RowDefinition Height="120" />
                    <RowDefinition Height="120" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Label Grid.Row="0"
                       Content="Refresh Token"
                       FontSize="30"
                       FontWeight="Bold"
                       VerticalContentAlignment="Center"
                       HorizontalContentAlignment="Center"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"></Label>

                <Grid Grid.Row="2"
                      Margin="20,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="AccessToken:"
                                   FontSize="16"    
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Margin="0,0,10,0" />
                        <TextBox Text="{Binding Path=AccessToken,Mode=OneWay}" IsReadOnly="True"
                                 FontSize="13"
                                VerticalContentAlignment="Top"
                                                          HorizontalAlignment="Left"
                                 TextWrapping="Wrap"
                                   Margin="10,0,10,0" />
                    </StackPanel>
                </Grid>
                
                <Grid Grid.Row="4"
                      Margin="10,0,50,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="RefreshToken:"
                                   FontSize="16"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                        <TextBox Text="{Binding Path=RefreshToken,Mode=OneWay}"
                                 IsReadOnly="True"
                                 FontSize="13"
                                 VerticalContentAlignment="Top"
                                 HorizontalAlignment="Left"
                                 TextWrapping="Wrap"
                                 Margin="10,0,10,0" />
                    </StackPanel>
                </Grid>

                <Button Grid.Row="6"
                        Margin="0,0,0,0"
                        Width="120"
                        Height="60"
                        Content="{materialDesign:PackIcon Kind=Toaster,Size=50}"
                        Command="{Binding Path=RefreshTokenCommand}"
                        Background="{Binding Path=(Border.Background),RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type Border}}}"
                        FontSize="18"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        ToolTip="确定" />

                <TextBlock Grid.Row="8"
                           Text="{Binding Path=ResponseMessage,Mode=OneWay}"
                          FontSize="22"
                           TextDecorations="Underline"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Left" 
                           VerticalAlignment="Center"
                           Margin="30,0,30,0">
                </TextBlock>
            </Grid>
        </Border>

        <Grid Visibility="{Binding Path=IsLoading,Converter={StaticResource booleanToVisibilityConverter}}"
              Margin="10,10,10,10">
            <Label Name="statusLabel"
                   Content="{Binding Path=StatusMessage,Mode=OneWay}"
                   Width="320"
                   Height="30"
                   FontSize="16"
                   FontWeight="Bold"
                   VerticalContentAlignment="Center"
                   HorizontalContentAlignment="Center"
                   Background="Green"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,30">
            </Label>
        </Grid>
    </Grid>
</UserControl>
